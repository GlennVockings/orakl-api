{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2017",
    "lib": ["ES2017", "DOM"],
    "types": ["node"],
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "ignoreDeprecations": "5.0",
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["src/**/*", "prisma/**/*"]
}
