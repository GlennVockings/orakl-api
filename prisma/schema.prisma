// ---------- Prisma config ----------
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------- Enums ----------
enum GameType {
  FAUX_STAKES
  PREDICTOR
}

enum GameStatus {
  DRAFT
  OPEN
  CLOSED
}

enum MemberRole {
  HOST
  ADMIN
  PLAYER
}

enum MarketStatus {
  OPEN
  CLOSED
  SETTLED
}

enum SelectionStatus {
  ACTIVE
  WINNER
  LOSER
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
}

enum LedgerType {
  CREDIT
  DEBIT
  PAYOUT
  REFUND
}

model User {
  id            String   @id @default(cuid())
  displayName   String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Full version auth:
  passwordHash String? // null allowed for prototype-only presets if you want

  // Relationships
  memberships          CompetitionMember[]
  competitionsCreated  Competition[]          @relation("CompetitionsCreatedBy")
  bets                 Bet[]
  ledgerTxns           CompetitionLedgerTxn[]
  leaderboardSnapshots LeaderboardSnapshot[]

  // Optional: tutorial state
  // onboarding OnboardingState?
  account Account[]
  session Session[]

  @@map("user")
}

model CompetitionMember {
  id            String     @id @default(cuid())
  competitionId String
  userId        String
  role          MemberRole @default(PLAYER)
  joinedAt      DateTime   @default(now())

  lastSeenAt DateTime @default(now())

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([competitionId, userId])
  @@index([userId])
  @@index([competitionId])
}

model Competition {
  id     String     @id @default(cuid())
  name   String
  status GameStatus @default(DRAFT)

  joinCode String @unique

  createdById String
  createdBy   User     @relation("CompetitionsCreatedBy", fields: [createdById], references: [id])
  gameType    GameType @default(FAUX_STAKES)

  // Helpful flags
  isDemo     Boolean @default(false) // for public demo mode later (still join-code controlled if you want)
  isTemplate Boolean @default(false) // if you ever want “copy this competition setup”

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  closedAt       DateTime?
  lastActivityAt DateTime  @default(now())

  // Relationships
  members               CompetitionMember[]
  fauxStakesCompetition FauxStakesCompetition?
  teams                 Team[]
  markets               Market[]
  bets                  Bet[]
  ledgerTxns            CompetitionLedgerTxn[]
  leaderboardSnapshots  LeaderboardSnapshot[]

  @@index([createdById])
}

model FauxStakesCompetition {
  id            String   @id @default(cuid())
  competitionId String   @unique
  startingChips Int      @default(1000)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
}

model Team {
  id            String @id @default(cuid())
  competitionId String
  name          String

  selections Selection[]

  // optional UI flair
  emoji String?
  color String?

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@unique([competitionId, name])
  @@index([competitionId])
}

model Market {
  id                   String                 @id @default(cuid())
  competitionId        String
  name                 String
  status               MarketStatus           @default(OPEN)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  ledgerTxns           CompetitionLedgerTxn[]
  leaderboardSnapshots LeaderboardSnapshot[]

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  selections  Selection[]

  @@unique([competitionId, name])
  @@index([competitionId])
  @@index([competitionId, status])
}

model Selection {
  id          String          @id @default(cuid())
  marketId    String
  teamId      String?
  team        Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  label       String?
  decimalOdds Decimal         @db.Decimal(8, 3)
  status      SelectionStatus @default(ACTIVE)

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  bets   Bet[]

  @@index([marketId])
  @@index([teamId])
}

model Bet {
  id              String                 @id @default(cuid())
  competitionId   String
  userId          String
  selectionId     String
  stake           Decimal                @db.Decimal(12, 2)
  oddsSnapshot    Decimal                @db.Decimal(8, 3)
  potentialReturn Decimal                @db.Decimal(12, 2)
  status          BetStatus              @default(PENDING)
  placedAt        DateTime               @default(now())
  settledAt       DateTime?
  ledgerTxns      CompetitionLedgerTxn[]

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  selection   Selection   @relation(fields: [selectionId], references: [id], onDelete: Cascade)

  @@index([competitionId, userId, status])
  @@index([selectionId])
}

model CompetitionLedgerTxn {
  id            String     @id @default(cuid())
  competitionId String
  userId        String
  type          LedgerType
  amount        Decimal    @db.Decimal(12, 2)

  betId String?
  bet   Bet?    @relation(fields: [betId], references: [id], onDelete: SetNull)

  marketId String?
  market   Market? @relation(fields: [marketId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([competitionId])
  @@index([userId, competitionId])
  @@index([betId])
  @@index([marketId])
}

// =======================
// Better Auth Models
// =======================

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Jwks {
  id         String   @id
  publicKey  String   @db.Text
  privateKey String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("jwks")
}

model LeaderboardSnapshot {
  id             String   @id @default(cuid())
  competitionId  String
  marketId       String
  userId         String
  settledBalance Decimal  @db.Decimal(12, 2)
  rank           Int
  createdAt      DateTime @default(now())

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  market      Market      @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([competitionId, createdAt])
  @@index([competitionId, userId, createdAt])
  @@index([marketId])
}
